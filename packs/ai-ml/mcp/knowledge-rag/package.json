{
  "name": "@craftsman/knowledge-rag-mcp",
  "version": "1.0.0",
  "description": "MCP server for RAG over local AI/Architecture knowledge base (Ollama)",
  "type": "module",
  "main": "dist/src/index.js",
  "bin": {
    "knowledge-rag-mcp": "dist/src/index.js"
  },
  "scripts": {
    "build": "tsc",
    "postinstall": "npm run build",
    "dev": "tsc --watch",
    "cli": "tsx scripts/cli.ts",
    "cli:sync": "tsx scripts/cli.ts sync",
    "cli:status": "tsx scripts/cli.ts status",
    "cli:list": "tsx scripts/cli.ts list",
    "cli:rebuild": "tsx scripts/cli.ts rebuild",
    "index": "tsx scripts/cli.ts sync",
    "index:ollama": "tsx scripts/cli.ts sync",
    "start": "node dist/src/index.js",
    "test": "tsx tests/vector-store.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-sqlite3": "^11.0.0",
    "pdf-parse": "^1.1.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^20.0.0",
    "@types/pdf-parse": "^1.1.4",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
